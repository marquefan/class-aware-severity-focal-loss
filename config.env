# Dataset paths
IMAGES_DIR=HAM10000_images
TRAIN_CSV=ham10000_bboxes_with_labels.csv
# VAL_CSV=ham10000_bboxes_fold0_val.csv
# TEST_CSV=ham10000_bboxes_fold0_test.csv

# Training hyperparameters
EPOCHS=100
BATCH_SIZE=16
ACCUM_STEPS=1
NUM_WORKERS=4
LR=0.0002
WEIGHT_DECAY=0.0001
BETA=0.999
GAMMA=2.0
EMBED_DIM=32
WARMUP_FREEZE_EPOCHS=1
SEED=17
MIN_SIZE=450
MAX_SIZE=600

# Wandb settings
WANDB=true
WANDB_PROJECT=cafl
DISABLE_CAFL=true  # set true to run vanilla RetinaNet baseline
# WANDB_ENTITY=your_team
WANDB_RUN_NAME=baseline-no-cafl
WANDB_MODE=online
